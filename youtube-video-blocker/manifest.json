{
  "manifest_version": 3,
  "name": "YouTube Video Blocker",
  "version": "1.0",
  "description": "Blocks distracting music videos with a helpful frog friend.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}